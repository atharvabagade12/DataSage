# DataSage Environment Variables
# Copy this file to .env and update with your values

# ===== DATABASE CONFIGURATION =====
# PostgreSQL connection details
POSTGRES_USER=datasage
POSTGRES_PASSWORD=datasage_dev_password
POSTGRES_DB=datasage_db

# Full database URL (used by backend)
# Format: postgresql://user:password@host:port/database
# For Docker: use service name 'postgres' as host
DATABASE_URL=postgresql://datasage:datasage_dev_password@postgres:5432/datasage_db

# ===== AUTHENTICATION =====
# Secret key for JWT token generation (change in production!)
SECRET_KEY=dev_secret_key_change_in_production_to_random_string

# JWT algorithm
ALGORITHM=HS256

# ===== DEVELOPMENT NOTES =====
# - For local development with Docker, use the service name 'postgres' as the database host
# - For production, generate a strong random SECRET_KEY
# - Never commit the .env file to version control
